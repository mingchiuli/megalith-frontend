{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/__tests__/*",
    "auto-imports.d.ts",
    "components.d.ts",
    "declarations.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "moduleResolution": "Bundler",
    "types": [
      "node",
      "element-plus/global",
      "vitest/globals"
    ]
  }
}
